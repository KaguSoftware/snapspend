{
  "expo": {
    "name": "SnapSpend",
    "slug": "snapspend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "snapspend",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.kagusoftware.snapspend",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "SnapSpend uses the camera to scan your receipts so expenses can be added automatically.",
        "NSPhotoLibraryUsageDescription": "SnapSpend lets you pick receipt photos from your library to extract expenses."
      }
    },
    "android": {
      "package": "com.kagusoftware.snapspend",
      "adaptiveIcon": {
        "backgroundColor": "#064e3b",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#064e3b",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "SnapSpend uses the camera to scan your receipts so expenses can be added automatically."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SnapSpend lets you pick receipt photos from your library to extract expenses."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
